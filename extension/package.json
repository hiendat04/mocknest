{
  "name": "mocknest-extension",
  "displayName": "MockNest",
  "description": "Instantly spin up a local mock API server from your OpenAPI spec",
  "version": "0.0.1",
  "publisher": "dat-mai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/openapi.{yaml,yml,json}"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mocknest.startServer",
        "title": "MockNest: Start Mock Server",
        "icon": "$(play)"
      },
      {
        "command": "mocknest.stopServer",
        "title": "MockNest: Stop Mock Server",
        "icon": "$(stop)"
      },
      {
        "command": "mocknest.selectSpec",
        "title": "MockNest: Select OpenAPI Spec File"
      },
      {
        "command": "mocknest.openApiTester",
        "title": "MockNest: Open API Tester",
        "icon": "$(beaker)"
      },
      {
        "command": "mocknest.restartServer",
        "title": "MockNest: Restart Mock Server",
        "icon": "$(refresh)"
      },
      {
        "command": "mocknest.clearRequestLog",
        "title": "MockNest: Clear Request Log",
        "icon": "$(clear-all)"
      },
      {
        "command": "mocknest.copyRequestLogAsCurl",
        "title": "MockNest: Copy Request as cURL",
        "icon": "$(clippy)"
      },
      {
        "command": "mocknest.toggleChaosMode",
        "title": "MockNest: Toggle Chaos Mode",
        "icon": "$(flame)"
      },
      {
        "command": "mocknest.setChaosLatency",
        "title": "MockNest: Set Chaos Latency",
        "icon": "$(clock)"
      },
      {
        "command": "mocknest.setChaosErrorRate",
        "title": "MockNest: Set Chaos Failure Rate",
        "icon": "$(pulse)"
      },
      {
        "command": "mocknest.resetChaosSettings",
        "title": "MockNest: Reset Chaos Settings",
        "icon": "$(discard)"
      },
      {
        "command": "mocknest.toggleStrictValidation",
        "title": "MockNest: Toggle Contract Validation",
        "icon": "$(shield)"
      },
      {
        "command": "mocknest.copyBaseUrl",
        "title": "MockNest: Copy Base URL",
        "icon": "$(link-external)"
      },
      {
        "command": "mocknest.exportRuntimeConfig",
        "title": "MockNest: Export Runtime Config JSON",
        "icon": "$(save-as)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mocknest",
          "title": "MockNest",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "mocknest": [
        {
          "id": "mocknest.routeTree",
          "name": "Mock Routes",
          "icon": "$(list-tree)"
        },
        {
          "id": "mocknest.requestLog",
          "name": "Request Log",
          "icon": "$(history)"
        },
        {
          "id": "mocknest.chaosControls",
          "name": "Chaos Controls",
          "icon": "$(flame)"
        }
      ]
    },
    "configuration": {
      "title": "MockNest",
      "properties": {
        "mocknest.port": {
          "type": "number",
          "default": 3001,
          "description": "Port for the mock server"
        },
        "mocknest.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Auto-start mock server when workspace opens"
        },
        "mocknest.maxLogEntries": {
          "type": "number",
          "default": 200,
          "minimum": 20,
          "description": "Maximum number of request log entries to keep in memory"
        },
        "mocknest.delay": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "description": "Simulated global network delay (in milliseconds) applied to mock responses."
        },
        "mocknest.errorRate": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1,
          "description": "Probability (0 to 1) of a request randomly failing with a 500 error to simulate network chaos."
        },
        "mocknest.strictValidation": {
          "type": "boolean",
          "default": false,
          "description": "Validate incoming request path/query/body against the OpenAPI contract and return 400 with details when invalid."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "mocknest.openApiTester",
          "when": "view == mocknest.routeTree",
          "group": "navigation@1"
        },
        {
          "command": "mocknest.clearRequestLog",
          "when": "view == mocknest.requestLog",
          "group": "navigation@2"
        },
        {
          "command": "mocknest.copyBaseUrl",
          "when": "view == mocknest.routeTree",
          "group": "navigation@2"
        },
        {
          "command": "mocknest.exportRuntimeConfig",
          "when": "view == mocknest.routeTree",
          "group": "navigation@3"
        },
        {
          "command": "mocknest.toggleChaosMode",
          "when": "view == mocknest.chaosControls",
          "group": "navigation@1"
        },
        {
          "command": "mocknest.toggleStrictValidation",
          "when": "view == mocknest.chaosControls",
          "group": "navigation@2"
        },
        {
          "command": "mocknest.resetChaosSettings",
          "when": "view == mocknest.chaosControls",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "mocknest.openApiTester",
          "when": "view == mocknest.routeTree && viewItem == routeItem",
          "group": "inline"
        },
        {
          "command": "mocknest.copyRequestLogAsCurl",
          "when": "view == mocknest.requestLog && viewItem == requestLogItem",
          "group": "inline"
        },
        {
          "command": "mocknest.toggleChaosMode",
          "when": "view == mocknest.chaosControls && viewItem == mocknest.chaosToggle",
          "group": "inline"
        },
        {
          "command": "mocknest.setChaosLatency",
          "when": "view == mocknest.chaosControls && viewItem == mocknest.chaosLatency",
          "group": "inline"
        },
        {
          "command": "mocknest.setChaosErrorRate",
          "when": "view == mocknest.chaosControls && viewItem == mocknest.chaosErrorRate",
          "group": "inline"
        },
        {
          "command": "mocknest.toggleStrictValidation",
          "when": "view == mocknest.chaosControls && viewItem == mocknest.strictValidation",
          "group": "inline"
        },
        {
          "command": "mocknest.resetChaosSettings",
          "when": "view == mocknest.chaosControls && viewItem == mocknest.chaosReset",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "mocknest-core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
